APP_NAME=DemonsUpload
APP_ENV=production
APP_KEY=base64:b/H/HMnR20ux469gg9b5iDVp0mNkL8KPtfQv3TuVA7s=
APP_DEBUG=false  # Cambiado de true
APP_URL=https://agresiva.vesercloud.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error  # Cambiado de debug

# ── Base de datos MariaDB ──────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=bd_laagresiva
DB_USERNAME=laagresiva
DB_PASSWORD="Po6KvJxladr$x8~8"

# ── Sesiones y caché en DB (no SQLite) ────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.vesercloud.com  # Cambiado para seguridad

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Storage público para imágenes ─────────────────
STORAGE_BASE_URL=https://agresiva.vesercloud.com/storage

# ── Límites de la plataforma ──────────────────────
MAX_FILE_SIZE_MB=5
DEFAULT_STORAGE_LIMIT_MB=1000

# ── Mail (configurar SMTP real en producción) ────
MAIL_MAILER=smtp  # Cambiado de log
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com  # Ejemplo: ajusta a tu proveedor
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_FROM_ADDRESS="noreply@agresiva.vesercloud.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS (no usado, dejar vacío) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Redis (no usado en pruebas) ───────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"